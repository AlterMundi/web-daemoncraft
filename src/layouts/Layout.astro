---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'DaemonCraft — Tu Daemon en Minecraft',
  description = 'Un agente autónomo de IA que vive en tu servidor de Minecraft. Tu compañero. Tu mundo. Tu aventura.',
} = Astro.props;

const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0A1428" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />

    <link rel="icon" type="image/svg+xml" href={`${base}daemon-icon.svg`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Russo+One&family=Chakra+Petch:wght@300;400;500;600;700&family=Press+Start+2P&family=JetBrains+Mono:wght@400;500;700&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>
  </head>
  <body class="font-body antialiased bg-navy-deep text-cream selection:bg-daemon selection:text-navy-deep">
    <slot />
  </body>
</html>

<style is:global>
  html {
    scroll-behavior: smooth;
  }
  body {
    background: radial-gradient(ellipse at top, #0A1428 0%, #050B15 60%, #03060B 100%);
    min-height: 100vh;
  }
  .pixelated {
    image-rendering: pixelated;
    image-rendering: -moz-crisp-edges;
  }
  .neon-cyan {
    text-shadow: 0 0 8px rgba(0, 217, 255, 0.6), 0 0 20px rgba(0, 217, 255, 0.4);
  }
  .neon-gold {
    text-shadow: 0 0 8px rgba(255, 184, 0, 0.6), 0 0 20px rgba(255, 184, 0, 0.4);
  }
  ::-webkit-scrollbar { width: 10px; }
  ::-webkit-scrollbar-track { background: #050B15; }
  ::-webkit-scrollbar-thumb { background: #00D9FF; border-radius: 5px; }
  ::-webkit-scrollbar-thumb:hover { background: #FFB800; }
</style>
