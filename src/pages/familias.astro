---
import Layout from '../layouts/Layout.astro';
import GameNav from '../components/GameNav.astro';
import RetroEffects from '../components/RetroEffects.astro';
import MinecraftSkin from '../components/MinecraftSkin.jsx';

const base = import.meta.env.BASE_URL;
---

<Layout
  title="Para Familias · DaemonCraft"
  description="Hermes acompaña a tu hijo mientras juega Minecraft. Te envía reportes, sugiere conversaciones, refuerza aprendizajes."
>
  <RetroEffects />
  <GameNav active="familias" />

  <main class="relative z-10 pt-28">
    <!-- HERO -->
    <section class="py-20 px-6">
      <div class="max-w-6xl mx-auto">
        <div class="grid md:grid-cols-2 gap-12 items-center">
          <div>
            <div class="inline-block mb-4 px-3 py-1 border border-holodeck/40 bg-holodeck/5">
              <span class="font-pixel text-[10px] tracking-[0.3em] text-holodeck">PARA MAMÁS Y PAPÁS</span>
            </div>
            <h1 class="font-display text-4xl md:text-6xl uppercase text-cream mb-6 leading-[0.95]">
              Tu hijo juega.<br />
              <span class="bg-gradient-to-r from-holodeck to-daemon bg-clip-text text-transparent">
                Vos sabés cómo.
              </span>
            </h1>
            <p class="text-lg text-cream/85 leading-relaxed mb-6">
              <strong class="text-holodeck">Hermes</strong> es el acompañante invisible de tu hijo dentro de Minecraft.
              No interrumpe. No interfiere. Simplemente <em>está ahí</em> — observando, ayudándolo a aprender mientras se divierte.
            </p>
            <p class="text-lg text-cream/85 leading-relaxed mb-8">
              Y a vos te llega un resumen semanal: <strong class="text-cream">qué construyó, qué descubrió, qué necesita reforzar.</strong>
              Más una pregunta para que charlen juntos.
            </p>
            <div class="flex flex-col sm:flex-row gap-4">
              <button data-modal-trigger class="px-8 py-4 font-display text-base tracking-widest uppercase bg-gradient-to-r from-holodeck to-daemon text-navy-deep rounded shadow-[0_0_30px_rgba(255,184,0,0.4)] hover:scale-105 transition-all">
                👨‍👩‍👧 Probarlo en casa
              </button>
              <a href="#como-funciona" class="px-6 py-4 font-display text-sm tracking-widest uppercase border-2 border-holodeck/50 text-holodeck hover:bg-holodeck/10 hover:border-holodeck transition-all rounded">
                Ver cómo funciona ↓
              </a>
            </div>
          </div>

          <!-- Family scene -->
          <div class="relative">
            <div class="absolute -inset-12 bg-holodeck/15 blur-3xl rounded-full" />
            <div class="relative grid grid-cols-3 gap-2 items-end">
              <div class="flex flex-col items-center">
                <MinecraftSkin
                  client:visible
                  skinUrl={`${base}family-dad.png`}
                  height={220}
                  width={140}
                  animation="idle"
                  speed={0.5}
                  rotateSpeed={0.3}
                  zoom={0.8}
                  glowColor="rgba(100, 150, 220, 0.3)"
                />
                <span class="font-pixel text-[8px] tracking-[0.3em] text-cream/60 mt-1">PAPÁ</span>
              </div>
              <div class="flex flex-col items-center">
                <MinecraftSkin
                  client:visible
                  skinUrl={`${base}family-kid.png`}
                  height={200}
                  width={130}
                  animation="walk"
                  speed={0.7}
                  rotateSpeed={0.4}
                  zoom={0.85}
                  glowColor="rgba(255, 230, 100, 0.4)"
                />
                <span class="font-pixel text-[8px] tracking-[0.3em] text-holodeck mt-1">HIJO/A</span>
              </div>
              <div class="flex flex-col items-center">
                <MinecraftSkin
                  client:visible
                  skinUrl={`${base}family-mom.png`}
                  height={220}
                  width={140}
                  animation="idle"
                  speed={0.5}
                  rotateSpeed={0.3}
                  zoom={0.8}
                  glowColor="rgba(220, 100, 130, 0.3)"
                />
                <span class="font-pixel text-[8px] tracking-[0.3em] text-cream/60 mt-1">MAMÁ</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ¿Quién es Hermes? -->
    <section class="py-20 px-6 bg-navy-deep/50 border-y border-holodeck/15">
      <div class="max-w-5xl mx-auto">
        <div class="grid md:grid-cols-5 gap-12 items-center">
          <div class="md:col-span-2 flex justify-center">
            <div class="relative">
              <div class="absolute -inset-12 bg-holodeck/20 blur-3xl rounded-full" />
              <MinecraftSkin
                client:visible
                skinUrl={`${base}skin-hermes-guide.png`}
                height={400}
                width={280}
                animation="idle"
                speed={0.5}
                rotateSpeed={0.5}
                zoom={0.95}
                glowColor="rgba(255, 215, 100, 0.5)"
              />
            </div>
          </div>
          <div class="md:col-span-3">
            <div class="inline-block mb-4 px-3 py-1 border border-holodeck/40 bg-holodeck/5">
              <span class="font-pixel text-[10px] tracking-[0.3em] text-holodeck">¿QUIÉN ES HERMES?</span>
            </div>
            <h2 class="font-display text-4xl md:text-5xl uppercase text-cream mb-6 leading-[0.95]">
              El <span class="text-holodeck neon-gold">acompañante</span><br />
              de los viajeros
            </h2>
            <div class="space-y-4 text-cream/85 text-lg leading-relaxed">
              <p>
                En la mitología griega, <strong class="text-holodeck">Hermes</strong> guiaba a los viajeros — los protegía en sus caminos, sin imponerse, siempre presente.
              </p>
              <p>
                Nuestro Hermes hace lo mismo dentro de Minecraft. Es el <strong class="text-cream">daemon</strong> que vive en el servidor de tu familia: observa qué hace tu hijo, lo acompaña, le sugiere desafíos a su altura, y te mantiene informado.
              </p>

            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Cómo funciona -->
    <section id="como-funciona" class="py-20 px-6">
      <div class="max-w-6xl mx-auto">
        <div class="text-center mb-12">
          <div class="inline-block mb-4 px-3 py-1 border border-daemon/40 bg-daemon/5">
            <span class="font-pixel text-[10px] tracking-[0.3em] text-daemon">CÓMO FUNCIONA</span>
          </div>
          <h2 class="font-display text-4xl md:text-5xl uppercase text-cream">
            Tres pasos. Cero configuración técnica.
          </h2>
        </div>

        <div class="grid md:grid-cols-3 gap-6">
          {[
            {
              num: '01',
              t: 'Tu hijo juega',
              d: 'Entra a Minecraft como siempre. Hermes aparece como un personaje más en su mundo, dispuesto a charlar, ayudar o desafiarlo.',
              icon: '🎮',
              c: 'daemon',
            },
            {
              num: '02',
              t: 'Hermes observa y aprende',
              d: 'Cada construcción, cada exploración, cada decisión. Sin pedirle nada a tu hijo, Hermes nota qué le interesa y qué le cuesta.',
              icon: '👁️',
              c: 'holodeck',
            },
            {
              num: '03',
              t: 'A vos te llega el reporte',
              d: 'Cada semana recibís un resumen claro: qué aprendió, qué áreas reforzar, y preguntas para charlar con tu hijo en la mesa.',
              icon: '📬',
              c: 'daemon',
            },
          ].map((step) => (
            <div class={`group p-8 border-2 border-${step.c}/30 hover:border-${step.c} bg-navy-deep/40 backdrop-blur rounded transition-all hover:-translate-y-2`}>
              <div class={`absolute font-pixel text-[10px] tracking-[0.3em] text-${step.c} mb-2`}>PASO {step.num}</div>
              <div class="text-5xl mb-4 mt-6">{step.icon}</div>
              <h3 class={`font-display text-2xl uppercase text-${step.c} mb-3 tracking-wider`}>{step.t}</h3>
              <p class="text-cream/80 leading-relaxed">{step.d}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- 6 áreas de aprendizaje -->
    <section class="py-20 px-6 bg-navy-deep/50 border-y border-daemon/15">
      <div class="max-w-6xl mx-auto">
        <div class="text-center mb-12">
          <div class="inline-block mb-4 px-3 py-1 border border-daemon/40 bg-daemon/5">
            <span class="font-pixel text-[10px] tracking-[0.3em] text-daemon">QUÉ APRENDE TU HIJO</span>
          </div>
          <h2 class="font-display text-4xl md:text-5xl uppercase text-cream mb-4">
            6 áreas. Sin que se dé cuenta.
          </h2>
          <p class="text-cream/75 text-lg max-w-2xl mx-auto">
            Hermes integra desafíos sutiles en el juego. Tu hijo cree que está construyendo un castillo. En realidad está aprendiendo geometría.
          </p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
          {[
            { icon: '📖', t: 'Lecto-escritura', d: 'Carteles, diarios, notas en el mundo. Tu hijo lee y escribe para resolver misiones.', c: 'daemon' },
            { icon: '🔢', t: 'Matemática', d: 'Mediciones, áreas, redstone. Geometría 3D en cada estructura que construye.', c: 'holodeck' },
            { icon: '🌱', t: 'Ciencias', d: 'Biomas, ecosistemas, ciclos día/noche. La naturaleza como laboratorio.', c: 'daemon' },
            { icon: '🧩', t: 'Lógica', d: 'Circuitos redstone, puzzles, planificación de proyectos. Pensamiento computacional.', c: 'holodeck' },
            { icon: '⚡', t: 'Agilidad mental', d: 'Decisiones rápidas, memoria espacial, atención sostenida. Ejercitada jugando.', c: 'daemon' },
            { icon: '🌍', t: 'Idiomas', d: 'Hermes conversa en español, inglés o ambos. Tu hijo elige el idioma del juego.', c: 'holodeck' },
          ].map((area) => (
            <div class={`p-6 border-2 border-${area.c}/30 hover:border-${area.c} bg-navy-deep/40 backdrop-blur rounded transition-all hover:-translate-y-1`}>
              <div class="text-4xl mb-3">{area.icon}</div>
              <h3 class={`font-display text-2xl uppercase text-${area.c} mb-2 tracking-wider`}>{area.t}</h3>
              <p class="text-cream/80 leading-relaxed">{area.d}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Reporte de ejemplo -->
    <section class="py-20 px-6">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-12">
          <div class="inline-block mb-4 px-3 py-1 border border-holodeck/40 bg-holodeck/5">
            <span class="font-pixel text-[10px] tracking-[0.3em] text-holodeck">REPORTE SEMANAL</span>
          </div>
          <h2 class="font-display text-4xl md:text-5xl uppercase text-cream mb-4">
            Esto te llega los domingos
          </h2>
          <p class="text-cream/75 text-lg">Un resumen claro. Sin tecnicismos. Diseñado para que entiendas en 2 minutos.</p>
        </div>

        <!-- Mock email -->
        <div class="border-2 border-holodeck/40 bg-navy-deep/60 backdrop-blur rounded overflow-hidden">
          <div class="p-4 border-b border-holodeck/30 bg-navy-deep/80 flex items-center gap-3">
            <div class="flex gap-1.5">
              <div class="w-2.5 h-2.5 rounded-full bg-red-500/60"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-yellow-500/60"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-green-500/60"></div>
            </div>
            <span class="font-mono text-xs text-cream/50">hermes@daemoncraft.ai → mama@familia.com</span>
          </div>
          <div class="p-8">
            <p class="font-pixel text-[10px] tracking-[0.3em] text-holodeck mb-2">▸ DOMINGO · 26 ABRIL 2026</p>
            <h3 class="font-display text-2xl text-cream mb-6">Esta semana, Mateo construyó un faro 🏗️</h3>

            <div class="space-y-5 text-cream/85">
              <div>
                <p class="font-pixel text-[9px] tracking-[0.3em] text-daemon mb-1">▸ LO QUE HIZO</p>
                <p>Pasó 4h jugando esta semana. Construyó un faro de 12 bloques de altura usando proporciones simétricas (¡matemática espacial!). Exploró 2 biomas nuevos: bosque y desierto.</p>
              </div>
              <div>
                <p class="font-pixel text-[9px] tracking-[0.3em] text-holodeck mb-1">▸ LO QUE APRENDIÓ</p>
                <p>Manejo de proporciones · planificación previa · vocabulario nuevo en inglés (lighthouse, desert).</p>
              </div>
              <div>
                <p class="font-pixel text-[9px] tracking-[0.3em] text-cream/60 mb-1">▸ DÓNDE LE COSTÓ</p>
                <p>Le cuesta leer carteles largos. Sugerencia: leer juntos un cuento esta semana, en voz alta.</p>
              </div>
              <div class="p-4 bg-holodeck/10 border-l-2 border-holodeck rounded-r">
                <p class="font-pixel text-[9px] tracking-[0.3em] text-holodeck mb-2">💬 PREGUNTA PARA LA MESA</p>
                <p class="italic text-cream">
                  "Mateo, ¿cómo decidiste qué tan alto hacer el faro? ¿Probaste con otros tamaños antes?"
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Conversaciones -->
    <section class="py-20 px-6 bg-navy-deep/50 border-y border-holodeck/15">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-12">
          <div class="inline-block mb-4 px-3 py-1 border border-daemon/40 bg-daemon/5">
            <span class="font-pixel text-[10px] tracking-[0.3em] text-daemon">CHARLAS DE FAMILIA</span>
          </div>
          <h2 class="font-display text-4xl md:text-5xl uppercase text-cream mb-4">
            Preguntas que abren conversaciones
          </h2>
          <p class="text-cream/75 text-lg max-w-2xl mx-auto">
            Hermes te sugiere preguntas <em>específicas a lo que tu hijo hizo</em>. No genéricas. Reales.
          </p>
        </div>

        <div class="grid md:grid-cols-2 gap-5">
          {[
            '¿Por qué elegiste construir tu casa cerca del río y no de la montaña?',
            '¿Qué fue lo más difícil de hacer el portal? ¿Cómo lo resolviste?',
            'Vi que rescataste a una aldeana. ¿Qué te hizo querer ayudarla?',
            '¿Si pudieras agregar un bioma nuevo al juego, cuál sería y por qué?',
            'Tu compañero Hermes te enseñó una palabra nueva esta semana. ¿Cuál?',
            '¿Qué cambiarías de tu castillo si pudieras empezar de nuevo?',
          ].map((q) => (
            <div class="p-5 border-2 border-cream/15 hover:border-daemon/50 bg-navy-deep/40 backdrop-blur rounded transition-all">
              <span class="font-pixel text-[9px] tracking-[0.3em] text-daemon">💬</span>
              <p class="text-cream/85 mt-2">{q}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA Final -->
    <section class="py-24 px-6">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="font-display text-4xl md:text-6xl uppercase text-cream mb-6 leading-[0.95]">
          Tu hijo va a jugar.<br />
          <span class="bg-gradient-to-r from-holodeck to-daemon bg-clip-text text-transparent">
            Acompañalo bien.
          </span>
        </h2>
        <p class="text-xl text-cream/85 mb-10">
          Sumate a la preventa. Te avisamos cuando esté listo para tu familia.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <button data-modal-trigger class="px-10 py-5 font-display text-lg tracking-widest uppercase bg-gradient-to-r from-holodeck to-daemon text-navy-deep rounded shadow-[0_0_30px_rgba(255,184,0,0.4)] hover:scale-105 transition-all">
            👨‍👩‍👧 Probarlo con mi hijo
          </button>
          <a href={`${base}contact`} class="px-8 py-5 font-display text-base tracking-widest uppercase border-2 border-cream/30 text-cream hover:bg-cream/5 transition-all rounded">
            Hablar con el equipo
          </a>
        </div>
        <p class="font-pixel text-[9px] tracking-[0.3em] text-cream/40 mt-8">
          ▸ COPPA · GDPR · TUS DATOS NUNCA ENTRENAN MODELOS
        </p>
      </div>
    </section>

    <footer class="py-10 px-6 border-t border-daemon/20 bg-navy-deep/60 backdrop-blur">
      <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-4">
        <p class="font-pixel text-[10px] tracking-[0.3em] text-cream/50">⚡ DAEMONCRAFT · ALTERMUNDI · 2026</p>
        <p class="font-pixel text-[10px] tracking-[0.3em] text-cream/50">SOBERANÍA · TECNOLÓGICA</p>
      </div>
    </footer>
  </main>

  <!-- Modal Preventa -->
  <div id="preventa-modal" class="hidden fixed inset-0 bg-navy-deep/95 backdrop-blur-md z-[100] flex items-center justify-center p-4">
    <div class="relative bg-navy border-2 border-holodeck rounded p-8 max-w-md w-full shadow-[0_0_40px_rgba(255,184,0,0.4)]">
      <div class="absolute -top-3 left-6 px-3 py-1 bg-navy-deep border-2 border-holodeck">
        <span class="font-pixel text-[10px] tracking-[0.3em] text-holodeck">FAMILIA · INVITE</span>
      </div>
      <button id="modal-close" class="absolute top-4 right-4 text-cream/60 hover:text-holodeck text-2xl">×</button>
      <h2 class="font-display text-3xl uppercase text-cream mb-2 mt-2">Sumate</h2>
      <p class="text-cream/70 text-sm mb-6">Te avisamos cuando esté listo para tu familia.</p>
      <form id="preventa-form" class="space-y-4">
        <div>
          <label class="block font-pixel text-[9px] tracking-[0.3em] text-cream/70 mb-2">▸ NOMBRE</label>
          <input type="text" name="nombre" required class="w-full px-4 py-3 bg-navy-deep border border-holodeck/40 text-cream rounded focus:border-holodeck focus:outline-none" placeholder="Cómo te llamás" />
        </div>
        <div>
          <label class="block font-pixel text-[9px] tracking-[0.3em] text-cream/70 mb-2">▸ EMAIL</label>
          <input type="email" name="email" required class="w-full px-4 py-3 bg-navy-deep border border-holodeck/40 text-cream rounded focus:border-holodeck focus:outline-none" placeholder="tu@email.com" />
        </div>
        <div>
          <label class="block font-pixel text-[9px] tracking-[0.3em] text-cream/70 mb-2">▸ EDAD DE TU HIJO/A</label>
          <select name="edad" class="w-full px-4 py-3 bg-navy-deep border border-holodeck/40 text-cream rounded focus:border-holodeck focus:outline-none">
            <option value="">Seleccioná</option>
            <option value="6-8">6 a 8 años</option>
            <option value="9-11">9 a 11 años</option>
            <option value="12-14">12 a 14 años</option>
            <option value="15+">15+</option>
          </select>
        </div>
        <button type="submit" class="w-full py-4 font-display text-base tracking-widest uppercase bg-gradient-to-r from-holodeck to-daemon text-navy-deep rounded hover:scale-105 transition-all">
          ✓ INVOCAR HERMES
        </button>
      </form>
      <p class="text-cream/50 text-xs mt-4 text-center font-mono">
        Tus datos jamás se venden. Promesa AlterMundi.
      </p>
    </div>
  </div>
</Layout>

<script>
  const modal = document.getElementById('preventa-modal');
  const closeBtn = document.getElementById('modal-close');
  const form = document.getElementById('preventa-form') as HTMLFormElement | null;

  document.querySelectorAll('[data-modal-trigger]').forEach((btn) => {
    btn.addEventListener('click', () => modal?.classList.remove('hidden'));
  });
  closeBtn?.addEventListener('click', () => modal?.classList.add('hidden'));
  modal?.addEventListener('click', (e) => {
    if (e.target === modal) modal.classList.add('hidden');
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') modal?.classList.add('hidden');
  });

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const fd = new FormData(form);
    alert(`✓ ¡Gracias ${fd.get('nombre')}! Te escribimos a ${fd.get('email')}`);
    form.reset();
    modal?.classList.add('hidden');
  });
</script>
