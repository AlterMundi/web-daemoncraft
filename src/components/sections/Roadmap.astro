---
const fases = [
  {
    n: '01',
    time: 'Abril 2026',
    title: 'Fundamentos',
    niño: 'MVP jugable: el Daemon se conecta, responde y puede construir.',
    familia: 'Landing page completa. Waitlist de 100+ interesados.',
  },
  {
    n: '02',
    time: 'Mayo–Junio 2026',
    title: 'Primera Camada',
    niño: 'Beta con 200 usuarios. Memoria persistente funcionando. Reportes Telegram activos.',
    familia: 'Acceso beta. Resúmenes semanales del progreso del niño.',
  },
  {
    n: '03',
    time: 'Julio–Septiembre 2026',
    title: 'Invocación Pública',
    niño: 'Launch público v1.0. Guardian Mode + Adventure Packs + Marketplace de SOULs.',
    familia: '1000+ usuarios activos. Seguridad COPPA/GDPR completa. Dashboard pedagógico.',
  },
  {
    n: '04',
    time: 'Octubre 2026+',
    title: 'El Reino de los Daemons',
    niño: '10K+ usuarios. Multi-daemon (varios en un servidor). VR/AR. Expansión a otros juegos.',
    familia: 'Comunidad global. Ecosistema de creadores. Series A en camino.',
  },
];
---
<section id="roadmap" class="relative py-24 md:py-36">
  <div class="container-narrow">
    <div class="max-w-3xl mb-16">
      <span class="h-mini">08 / Roadmap</span>
      <div class="w-12 h-0.5 bg-daemon mt-3 mb-6"></div>
      <h2 class="h-display">De compañero a ecosistema</h2>
    </div>

    <div class="relative">
      <!-- línea vertical central -->
      <div class="hidden md:block absolute left-1/2 top-0 bottom-0 w-0.5 bg-daemon/20 -translate-x-1/2"></div>

      <div class="space-y-12 md:space-y-20">
        {fases.map((f, i) => (
          <div class={`relative grid md:grid-cols-2 gap-6 md:gap-16 ${i % 2 === 0 ? '' : 'md:[&>*:first-child]:order-2'}`}>
            <!-- bloque fase -->
            <div class={i % 2 === 0 ? 'md:text-right' : ''}>
              <div class={`inline-flex items-center gap-3 ${i % 2 === 0 ? 'md:flex-row-reverse' : ''}`}>
                <span class="block-icon !w-4 !h-4"></span>
                <div>
                  <span class="font-display text-daemon text-xs">FASE {f.n}</span>
                  <span class="font-serif italic text-daemon text-sm ml-3">{f.title}</span>
                </div>
              </div>
              <div class="font-mono text-[11px] uppercase tracking-widest text-teal-digital mt-2 mb-4">{f.time}</div>
              <div class={`space-y-3 ${i % 2 === 0 ? 'md:ml-auto md:max-w-sm' : 'md:max-w-sm'}`}>
                <div>
                  <div class="font-mono text-[10px] uppercase tracking-wider text-cream/50 mb-1">El niño vive</div>
                  <p class="text-cream/90 text-sm">{f.niño}</p>
                </div>
                <div>
                  <div class="font-mono text-[10px] uppercase tracking-wider text-cream/50 mb-1">La familia recibe</div>
                  <p class="text-cream/70 text-sm">{f.familia}</p>
                </div>
              </div>
            </div>
            <!-- punto central -->
            <div class="hidden md:flex items-start justify-center relative">
              <div class="w-6 h-6 bg-void border-2 border-daemon z-10 mt-1"
                   style="box-shadow: inset 0 0 0 2px rgba(255,87,34,0.3);"></div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
