---
import SkyBackground from '../SkyBackground.astro';
import GrassFloor from '../GrassFloor.astro';
import SteveDaemon3D from '../SteveDaemon3D.jsx';
const skinUrl = `${import.meta.env.BASE_URL}skin-daemon.png`;
---
<section id="top" class="relative min-h-[100vh] overflow-hidden pt-10">
  <!-- cielo animado -->
  <SkyBackground />

  <!-- piso pasto con árboles -->
  <GrassFloor />

  <!-- contenido -->
  <div class="relative container-narrow pt-10 md:pt-20 pb-32 md:pb-40 min-h-[90vh] flex items-center">
    <div class="grid md:grid-cols-[1.1fr_1fr] gap-10 md:gap-12 items-center w-full">
      <!-- copy -->
      <div class="space-y-6 md:space-y-7">
        <div class="inline-flex items-center gap-2 bg-void-light/90 border-2 border-daemon/30 px-3 py-1.5 shadow-pixel animate-pulse-daemon">
          <span class="w-2 h-2 bg-daemon animate-pulse"></span>
          <span class="font-mono text-[10px] md:text-xs uppercase tracking-widest text-cream">
            Fase 0: Fundamentos · Abril 2026
          </span>
        </div>

        <h1 class="h-display text-mc text-cream">
          Un daemon<br/>
          <span class="text-daemon">vive en tu</span><br/>
          servidor.
        </h1>

        <p class="font-sans text-lg md:text-xl text-cream/90 leading-relaxed max-w-xl bg-void-light/90 border-2 border-daemon/20 p-4 md:p-5 shadow-pixel">
          Daemon es un <strong>agente autónomo de IA</strong> que habita tu mundo de Minecraft.
          Juega, protege, aprende de vos y reporta a los tuyos.
          <span class="text-daemon font-semibold">Nunca duerme. Nunca olvida.</span>
        </p>

        <div class="flex flex-wrap gap-3 pt-2">
          <a href="#companeros" class="btn-mc btn-mc-daemon">
            Invocar tu entidad →
          </a>
          <a href="#como-funciona" class="btn-mc btn-mc-wood">
            Ver cómo funciona
          </a>
        </div>

        <!-- Stats rápidos -->
        <div class="flex flex-wrap gap-6 pt-4">
          <div class="flex items-center gap-2">
            <div class="w-6 h-6 bg-grass border-2 border-grass-dark"></div>
            <div>
              <div class="font-display text-[10px] text-cream text-mc">JAVA · BEDROCK</div>
              <div class="font-mono text-[10px] text-cream/70 text-mc">Cualquier servidor</div>
            </div>
          </div>
          <div class="flex items-center gap-2">
            <div class="w-6 h-6 bg-daemon border-2 border-daemon-dark animate-pulse"></div>
            <div>
              <div class="font-display text-[10px] text-cream text-mc">INSTANT DEPLOY</div>
              <div class="font-mono text-[10px] text-cream/70 text-mc">30 segundos</div>
            </div>
          </div>
          <div class="flex items-center gap-2">
            <div class="w-6 h-6 bg-cyan border-2 border-cyan-dark"></div>
            <div>
              <div class="font-display text-[10px] text-cream text-mc">DESDE $0</div>
              <div class="font-mono text-[10px] text-cream/70 text-mc">Free tier</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Steve-Daemon 3D con "plataforma" -->
      <div class="relative">
        <div class="absolute inset-x-0 bottom-0 h-24 flex items-end justify-center">
          <div class="w-48 h-4 bg-grass border-x-4 border-b-4 border-grass-dark" style="box-shadow: inset 0 4px 0 0 #94C95C;"></div>
        </div>
        <SteveDaemon3D client:only="react" skinUrl={skinUrl} height={480} />

        <!-- Name tag flotante -->
        <div class="absolute top-6 left-1/2 -translate-x-1/2 entity-tag animate-bob">
          DaemonCraft
        </div>
      </div>
    </div>
  </div>
</section>
