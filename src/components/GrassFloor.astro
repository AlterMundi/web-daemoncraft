---
// Piso de pasto Minecraft con árboles y flores en la distancia
---
<div class="grass-floor absolute bottom-0 left-0 right-0 pointer-events-none" aria-hidden="true">
  <!-- silueta de árboles + colinas al fondo -->
  <svg viewBox="0 0 320 80" class="w-full h-28 md:h-36" preserveAspectRatio="none" shape-rendering="crispEdges">
    <!-- colinas distantes -->
    <g fill="#94C95C" opacity="0.65">
      <rect x="0" y="55" width="60" height="25"/>
      <rect x="10" y="50" width="40" height="5"/>
      <rect x="20" y="45" width="20" height="5"/>
      <rect x="80" y="60" width="70" height="20"/>
      <rect x="100" y="55" width="40" height="5"/>
      <rect x="170" y="58" width="50" height="22"/>
      <rect x="240" y="52" width="80" height="28"/>
      <rect x="260" y="48" width="40" height="4"/>
    </g>

    <!-- árboles pequeños -->
    <g>
      <!-- árbol 1 -->
      <rect x="40" y="35" width="12" height="12" fill="#3B7A2E"/>
      <rect x="42" y="32" width="8"  height="3"  fill="#4B9639"/>
      <rect x="45" y="47" width="2"  height="8"  fill="#6B4423"/>
      <!-- árbol 2 -->
      <rect x="110" y="40" width="14" height="12" fill="#3B7A2E"/>
      <rect x="112" y="37" width="10" height="3"  fill="#4B9639"/>
      <rect x="116" y="52" width="2"  height="6"  fill="#6B4423"/>
      <!-- árbol 3 -->
      <rect x="195" y="38" width="16" height="14" fill="#3B7A2E"/>
      <rect x="198" y="35" width="10" height="3"  fill="#4B9639"/>
      <rect x="202" y="52" width="2"  height="6"  fill="#6B4423"/>
      <!-- árbol 4 -->
      <rect x="275" y="32" width="18" height="16" fill="#3B7A2E"/>
      <rect x="278" y="28" width="12" height="4"  fill="#4B9639"/>
      <rect x="283" y="48" width="2"  height="10" fill="#6B4423"/>
    </g>

    <!-- capa pasto frontal (verde top + tierra bajo) -->
    <rect x="0" y="60" width="320" height="4"  fill="#94C95C"/>
    <rect x="0" y="64" width="320" height="2"  fill="#7CAC50"/>
    <rect x="0" y="66" width="320" height="14" fill="#8B5A3C"/>
    <!-- detalles tierra -->
    <g fill="#6B4423">
      <rect x="10"  y="70" width="6" height="2"/>
      <rect x="50"  y="74" width="4" height="2"/>
      <rect x="90"  y="68" width="3" height="2"/>
      <rect x="140" y="72" width="5" height="2"/>
      <rect x="200" y="70" width="4" height="2"/>
      <rect x="260" y="74" width="6" height="2"/>
      <rect x="300" y="68" width="3" height="2"/>
    </g>
    <!-- flores -->
    <g>
      <rect x="30"  y="58" width="2" height="2" fill="#FF5544"/>
      <rect x="75"  y="58" width="2" height="2" fill="#FFE44A"/>
      <rect x="150" y="58" width="2" height="2" fill="#FF5544"/>
      <rect x="220" y="58" width="2" height="2" fill="#FFE44A"/>
      <rect x="290" y="58" width="2" height="2" fill="#FF5544"/>
    </g>
  </svg>
</div>
